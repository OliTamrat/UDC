# UDC Water Resources Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values

# Database path (default: ./data/udc-water.db for local SQLite)
# For Azure PostgreSQL, use: postgresql://user:password@host:5432/dbname
# DB_PATH=./data/udc-water.db

# API key for the /api/ingest endpoint (optional, but recommended in production)
# Generate with: openssl rand -hex 32
# INGEST_API_KEY=your-secret-key-here

# Future: Azure PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@your-server.postgres.database.azure.com:5432/udc_water?sslmode=require
