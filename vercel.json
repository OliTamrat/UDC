{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "claude/*": false
    }
  },
  "functions": {
    "src/app/api/**/*.ts": {
      "includeFiles": "data/**",
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/ingest?source=usgs",
      "schedule": "0 6 * * *"
    }
  ]
}
