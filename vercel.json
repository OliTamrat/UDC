{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/ingest?source=usgs",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/ingest?source=epa",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/ingest?source=wqp",
      "schedule": "0 8 * * 1"
    }
  ]
}
